rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ========================================
    // FONCTIONS DE SECURITE
    // ========================================

    function signedIn() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return signedIn() && getUserData().role == "admin";
    }

    function isAdminOrGestionnaire() {
      return signedIn() && getUserData().role in ["admin", "gestionnaire"];
    }

    function isProf() {
      return signedIn() && getUserData().role == "prof";
    }

    function isEleve() {
      return signedIn() && getUserData().role == "eleve";
    }

    function isParent() {
      return signedIn() && getUserData().role == "parent";
    }

    function isStaff() {
      return signedIn() && getUserData().role in ["admin", "gestionnaire", "prof"];
    }

    // ========================================
    // FONCTIONS MULTI-TENANT
    // ========================================

    function getUserSchoolId() {
      return getUserData().schoolId;
    }

    function belongsToUserSchool() {
      return resource.data.schoolId == getUserSchoolId();
    }

    function createdWithUserSchool() {
      return request.resource.data.schoolId == getUserSchoolId();
    }

    function isSuperAdmin() {
      return signedIn() && exists(/databases/$(database)/documents/superadmins/$(request.auth.uid));
    }

    // ========================================
    // REGLES PAR COLLECTION
    // ========================================

    // USERS - Seuls les admins peuvent creer/modifier des utilisateurs
    match /users/{userId} {
      allow read: if isStaff() || request.auth.uid == userId;
      allow create: if isAdmin();
      allow update: if isAdmin() ||
        (request.auth.uid == userId &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['lastSeen', 'nom', 'prenom', 'telephone', 'fcmTokens']));
      allow delete: if isAdmin();
    }

    // ELEVES - Staff peut gerer, parents/eleves lecture limitee
    // SECURITE: Isolation multi-tenant stricte sur ecriture
    match /eleves/{eleveId} {
      allow read: if (isStaff() && belongsToUserSchool()) ||
        (isParent() && eleveId in getUserData().enfantsIds) ||
        (isEleve() && getUserData().eleveId == eleveId);
      allow create: if isAdminOrGestionnaire() && createdWithUserSchool();
      allow update: if isAdminOrGestionnaire() && belongsToUserSchool();
      allow delete: if isAdminOrGestionnaire() && belongsToUserSchool();
    }

    // PROFESSEURS
    match /professeurs/{profId} {
      allow read: if (isStaff() && belongsToUserSchool()) ||
        (isProf() && getUserData().professeurId == profId);
      allow create: if isAdminOrGestionnaire() && createdWithUserSchool();
      allow update, delete: if isAdminOrGestionnaire() && belongsToUserSchool();
    }

    // COURS - Isolation multi-tenant
    match /cours/{coursId} {
      allow read: if (isStaff() && belongsToUserSchool()) ||
        (isEleve() && resource.data.classe == get(/databases/$(database)/documents/eleves/$(getUserData().eleveId)).data.classe && belongsToUserSchool()) ||
        (isParent() && belongsToUserSchool());
      allow create: if isStaff() && createdWithUserSchool();
      allow update, delete: if isStaff() && belongsToUserSchool();
    }

    // PRESENCES - Isolation multi-tenant
    match /presences/{coursId} {
      allow read: if isStaff() && belongsToUserSchool();
      allow create: if isStaff() && createdWithUserSchool();
      allow update: if isStaff() && belongsToUserSchool();
      allow delete: if isAdminOrGestionnaire() && belongsToUserSchool();

      match /appels/{eleveId} {
        allow read: if (isStaff() && get(/databases/$(database)/documents/presences/$(coursId)).data.schoolId == getUserSchoolId()) ||
          (isEleve() && getUserData().eleveId == eleveId) ||
          (isParent() && eleveId in getUserData().enfantsIds);
        allow write: if isStaff() && get(/databases/$(database)/documents/presences/$(coursId)).data.schoolId == getUserSchoolId();
      }
    }

    // PAIEMENTS - Donnees sensibles, isolation multi-tenant stricte
    match /paiements/{paiementId} {
      allow read: if (isAdminOrGestionnaire() && belongsToUserSchool()) ||
        (isParent() && resource.data.eleveId in getUserData().enfantsIds);
      allow create: if isAdminOrGestionnaire() && createdWithUserSchool();
      allow update, delete: if isAdminOrGestionnaire() && belongsToUserSchool();
    }

    // DISCIPLINE - Isolation multi-tenant
    match /discipline/{docId} {
      allow read: if (isStaff() && belongsToUserSchool()) ||
        (isParent() && resource.data.eleveId in getUserData().enfantsIds) ||
        (isEleve() && resource.data.eleveId == getUserData().eleveId);
      allow create: if isStaff() && createdWithUserSchool();
      allow update, delete: if isStaff() && belongsToUserSchool();
    }

    match /discipline_logs/{docId} {
      allow read, write: if isAdminOrGestionnaire() && belongsToUserSchool();
    }

    // CAHIER DE TEXTE - Isolation multi-tenant
    match /cahier/{docId} {
      allow read: if isStaff() && belongsToUserSchool();
      allow create: if isStaff() && createdWithUserSchool();
      allow update: if (isAdmin() && belongsToUserSchool()) ||
        (isProf() && resource.data.profId == request.auth.uid && belongsToUserSchool());
      allow delete: if isAdminOrGestionnaire() && belongsToUserSchool();
    }

    // MESSAGES - SECURITE: lecture restreinte aux participants uniquement
    // Fix: avant c'etait "allow read: if signedIn()" — n'importe qui pouvait lire tous les messages
    match /messages/{messageId} {
      allow read: if signedIn() && (
        resource.data.senderId == request.auth.uid ||
        resource.data.recipientId == request.auth.uid ||
        (resource.data.participants != null && request.auth.uid in resource.data.participants)
      );
      allow create: if signedIn();
      allow delete: if isAdmin() || resource.data.senderId == request.auth.uid;
      allow update: if (isAdmin() || resource.data.senderId == request.auth.uid ||
        resource.data.recipientId == request.auth.uid) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read', 'readAt', 'deletedAt']);
    }

    // ALERTS - Isolation multi-tenant
    // Fix: avant c'etait "allow read: if signedIn()" sans schoolId
    match /alerts/{alertId} {
      allow read: if signedIn() && belongsToUserSchool();
      allow create: if isAdminOrGestionnaire() && createdWithUserSchool();
      allow update, delete: if isAdminOrGestionnaire() && belongsToUserSchool();
    }

    // CLASSES - Isolation multi-tenant
    // Fix: avant c'etait "allow read: if signedIn()" sans schoolId
    match /classes/{classeId} {
      allow read: if signedIn() && belongsToUserSchool();
      allow create: if isAdminOrGestionnaire() && createdWithUserSchool();
      allow update, delete: if isAdminOrGestionnaire() && belongsToUserSchool();
    }

    // CORBEILLE - Admin uniquement, isolation multi-tenant
    match /corbeille/{docId} {
      allow read: if isAdmin() && belongsToUserSchool();
      allow create: if isAdmin() && createdWithUserSchool();
      allow update, delete: if isAdmin() && belongsToUserSchool();
    }

    // CONNECTION LOGS - Isolation multi-tenant stricte
    // Fix: avant les logs de toutes les ecoles etaient lisibles par tout admin
    match /connection_logs/{logId} {
      allow read: if isAdminOrGestionnaire() && resource.data.schoolId == getUserSchoolId();
      allow create: if signedIn() &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.schoolId == getUserSchoolId();
      allow update: if signedIn() && resource.data.userId == request.auth.uid &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['logoutAt']);
      allow delete: if isAdmin() && resource.data.schoolId == getUserSchoolId();
    }

    // ONLINE USERS - Chaque utilisateur gere sa propre entree
    match /online_users/{userId} {
      allow read: if isAdminOrGestionnaire();
      allow create, update: if signedIn() && request.auth.uid == userId;
      allow delete: if signedIn() && (request.auth.uid == userId || isAdmin());
    }

    // DEPENSES - Admin/gestionnaire, isolation multi-tenant
    match /depenses/{depenseId} {
      allow read: if isAdminOrGestionnaire() && belongsToUserSchool();
      allow create: if isAdminOrGestionnaire() && createdWithUserSchool();
      allow update, delete: if isAdminOrGestionnaire() && belongsToUserSchool();
    }

    // SALAIRES - Admin/gestionnaire, isolation multi-tenant
    match /salaires/{salaireId} {
      allow read: if isAdminOrGestionnaire() && belongsToUserSchool();
      allow create: if isAdminOrGestionnaire() && createdWithUserSchool();
      allow update, delete: if isAdminOrGestionnaire() && belongsToUserSchool();
    }

    // AUDIT LOGS - Lecture admin, ecriture par Cloud Functions uniquement
    match /audit_logs/{logId} {
      allow read: if isAdminOrGestionnaire() && resource.data.schoolId == getUserSchoolId();
      allow write: if false;
    }

    // SAUVEGARDES
    match /sauvegardes/{docId} {
      allow read: if isAdminOrGestionnaire() && resource.data.schoolId == getUserSchoolId();
      allow create: if isAdminOrGestionnaire() && createdWithUserSchool();
      allow update, delete: if false;
    }

    // CONFIG - Admin uniquement
    match /config/{docId} {
      allow read: if isAdminOrGestionnaire();
      allow write: if isAdmin();
    }

    // MATIERES - Isolation multi-tenant
    // Fix: avant c'etait "allow read: if signedIn()" sans schoolId
    match /matieres/{matiereId} {
      allow read: if signedIn() && belongsToUserSchool();
      allow create: if isAdminOrGestionnaire() && createdWithUserSchool();
      allow update, delete: if isAdminOrGestionnaire() && belongsToUserSchool();
    }

    // EMPLOI DU TEMPS - Isolation multi-tenant
    // Fix: avant c'etait "allow read: if signedIn()" sans schoolId
    match /emploi_du_temps/{creneauId} {
      allow read: if signedIn() && belongsToUserSchool();
      allow create: if isAdminOrGestionnaire() && createdWithUserSchool();
      allow update, delete: if isAdminOrGestionnaire() && belongsToUserSchool();
    }

    // EVALUATIONS - Isolation multi-tenant
    match /evaluations/{evaluationId} {
      allow read: if (isStaff() && belongsToUserSchool()) ||
        (isEleve() && resource.data.classe == get(/databases/$(database)/documents/eleves/$(getUserData().eleveId)).data.classe && belongsToUserSchool()) ||
        (isParent() && belongsToUserSchool());
      allow create, update: if isStaff() && belongsToUserSchool();
      allow delete: if isAdminOrGestionnaire() && belongsToUserSchool();
    }

    // NOTES - Isolation multi-tenant
    match /notes/{noteId} {
      allow read: if (isStaff() && belongsToUserSchool()) ||
        (isEleve() && resource.data.eleveId == getUserData().eleveId) ||
        (isParent() && resource.data.eleveId in getUserData().enfantsIds);
      allow create, update: if isStaff() && belongsToUserSchool();
      allow delete: if isAdminOrGestionnaire() && belongsToUserSchool();
    }

    // NOTIFICATIONS - Chacun voit ses notifications
    match /notifications/{notifId} {
      allow read: if signedIn() && resource.data.recipientId == request.auth.uid;
      allow update: if signedIn() && resource.data.recipientId == request.auth.uid &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'readAt']);
      allow create: if isStaff();
      allow delete: if isAdmin();
    }

    match /notification_config/{docId} {
      allow read, write: if isAdmin();
    }

    // BULLETINS - Isolation multi-tenant
    match /bulletins/{bulletinId} {
      allow read: if (isStaff() && belongsToUserSchool()) ||
        (isEleve() && resource.data.eleveId == getUserData().eleveId) ||
        (isParent() && resource.data.eleveId in getUserData().enfantsIds);
      allow create, update: if isStaff() && belongsToUserSchool();
      allow delete: if isAdmin() && belongsToUserSchool();
    }

    // ARCHIVES - Admin lecture seule (ecriture par CF)
    match /archives/{annee}/{collection}/{docId} {
      allow read: if isAdmin() && getUserSchoolId() != null;
      allow write: if false;
    }

    // SCHOOLS - Super admin tout, membres de l'ecole lecture
    match /schools/{schoolId} {
      allow read: if isSuperAdmin() ||
        (signedIn() && getUserData().schoolId == schoolId);
      allow create: if isSuperAdmin();
      allow update: if isSuperAdmin() ||
        (isAdmin() && getUserData().schoolId == schoolId);
      allow delete: if isSuperAdmin();
    }

    // SCHOOL SUBSCRIPTIONS
    match /school_subscriptions/{schoolId} {
      allow read: if isSuperAdmin() ||
        (isAdminOrGestionnaire() && getUserData().schoolId == schoolId);
      allow write: if isSuperAdmin();
    }

    // SUPER ADMINS - Lecture seule par les super admins
    match /superadmins/{uid} {
      allow read: if isSuperAdmin();
      allow write: if false;
    }

    // ADMISSIONS - Soumission publique, admin de l'ecole gere
    match /admissions/{admissionId} {
      allow create: if request.resource.data.keys().hasAll(['schoolId', 'nom', 'prenom'])
        && request.resource.data.schoolId is string
        && request.resource.data.schoolId.size() > 0;
      allow read, update, delete: if isAdminOrGestionnaire() &&
        resource.data.schoolId == getUserData().schoolId;
    }

    // TRANSPORT ROUTES
    match /transport_routes/{routeId} {
      allow read: if isStaff() && belongsToUserSchool();
      allow write: if isAdminOrGestionnaire() &&
        (resource == null || belongsToUserSchool());
    }

    // BIBLIOTHEQUE - Isolation multi-tenant
    // Fix: avant c'etait "allow read: if signedIn()" sans schoolId
    match /livres/{livreId} {
      allow read: if signedIn() && belongsToUserSchool();
      allow create: if isAdminOrGestionnaire() && createdWithUserSchool();
      allow update, delete: if isAdminOrGestionnaire() && belongsToUserSchool();
    }

    match /emprunts/{empruntId} {
      allow read: if (isStaff() && belongsToUserSchool()) ||
        (isEleve() && resource.data.eleveId == getUserData().eleveId) ||
        (isParent() && resource.data.eleveId in getUserData().enfantsIds);
      allow create: if isStaff() && createdWithUserSchool();
      allow update, delete: if isStaff() && belongsToUserSchool();
    }

    // LMS DEVOIRS / SUBMISSIONS - Isolation multi-tenant
    match /devoirs/{devoirId} {
      allow read: if (isStaff() && belongsToUserSchool()) ||
        (isEleve() && resource.data.classe == get(/databases/$(database)/documents/eleves/$(getUserData().eleveId)).data.classe && belongsToUserSchool()) ||
        (isParent() && belongsToUserSchool());
      allow create, update: if isStaff() && belongsToUserSchool();
      allow delete: if isAdminOrGestionnaire() && belongsToUserSchool();
    }

    match /submissions/{submissionId} {
      allow read: if (isStaff() && belongsToUserSchool()) ||
        (isEleve() && resource.data.eleveId == getUserData().eleveId);
      allow create: if isEleve() && request.resource.data.eleveId == request.auth.uid;
      allow update: if isStaff() && belongsToUserSchool();
      allow delete: if isAdminOrGestionnaire() && belongsToUserSchool();
    }

    // HR - LEAVE REQUESTS
    match /leave_requests/{requestId} {
      allow read: if isAdminOrGestionnaire() && belongsToUserSchool() ||
        (isStaff() && resource.data.userId == request.auth.uid);
      allow create: if isStaff() && request.resource.data.userId == request.auth.uid;
      allow update: if (isAdminOrGestionnaire() && belongsToUserSchool()) ||
        (isStaff() && resource.data.userId == request.auth.uid &&
         resource.data.statut == "en_attente");
      allow delete: if isAdmin() && belongsToUserSchool();
    }
  }
}
